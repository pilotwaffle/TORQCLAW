{
  "name": "torqclaw-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "engine:setup": "cd engines/hermes_kernel && uv sync && git submodule update --init --recursive",
    "model:setup": "ollama create torq-local -f ops/Modelfile",
    "stats": "node ops/stats.mjs",
    "contracts:check": "pnpm --filter @torqclaw/contracts check",
    "bench": "node --env-file=.env ops/bench.mjs",
    "bench:quick": "node --env-file=.env ops/bench.mjs --quick --no-score",
    "test": "vitest run",
    "graphify:profiles": "graphify profiles",
    "graphify:build:product": "graphify update .",
    "graphify:build:vendor": "cmd /c \"set GRAPHIFY_OUT=%CD%\\graphify-vendor&& graphify update engines/hermes_kernel/vendor/hermes-agent\"",
    "graphify:fitness": "graphify fitness --profile product --strict",
    "graphify:smoke": "python scripts/test_graphify_smoke.py"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "better-sqlite3": "^12",
    "jsdom": "^25",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2",
    "ws": "^8"
  }
}
