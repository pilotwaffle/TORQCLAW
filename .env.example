TORQCLAW_GATEWAY_TOKEN=change-me
TORQCLAW_DATA_DIR=
HERMES_ENGINE_URL=http://127.0.0.1:8000/mcp
HERMES_ENGINE_TOKEN=
OLLAMA_HOST=http://localhost:11434
TORQCLAW_LOCAL_MODEL=torq-local
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18790/ws
NEXT_PUBLIC_GATEWAY_TOKEN=change-me

# Hermes engine model config (FRONTIER tier). Leave unset to run in stub mode.
# DEFAULT recommendation = DeepSeek v4-flash: cheapest capable workhorse
# (~$0.14-0.28/M, fast, 1M context). Bring your own provider key.
#   DeepSeek:   HERMES_PROVIDER=deepseek   HERMES_MODEL=deepseek-v4-flash
#               HERMES_BASE_URL=https://api.deepseek.com
#   Anthropic:  HERMES_PROVIDER=anthropic  HERMES_MODEL=claude-sonnet-4-6
#   OpenRouter: HERMES_PROVIDER=openrouter HERMES_MODEL=anthropic/claude-sonnet-4.6
HERMES_MODEL=
HERMES_PROVIDER=
HERMES_API_KEY=
HERMES_BASE_URL=
HERMES_MAX_ITERATIONS=30
HERMES_DISABLED_TOOLSETS=delegation

# Coding-task model override (optional). When a task is COMPLEX_CODING the engine
# uses these instead of the default — e.g. Kimi K2.7 Code (256K ctx, agentic
# coding). Leave the MODEL blank to use the default provider for coding too.
HERMES_CODING_PROVIDER=kimi-for-coding
HERMES_CODING_MODEL=kimi-k2.7-code
HERMES_CODING_API_KEY=
HERMES_CODING_BASE_URL=https://api.kimi.com/coding

# Slow local GPU: route the confident-middle to cloud (privacy/LOCAL_ONLY still local).
TORQCLAW_PREFER_CLOUD=1
