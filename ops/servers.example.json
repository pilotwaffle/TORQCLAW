{
  "servers": [
    {
      "id": "filesystem",
      "transport": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/workspace"]
      },
      "approvalPatterns": ["write", "edit", "move", "create"],
      "pathArgKeys": ["path", "paths", "source", "destination"],
      "paths": {
        "read": ["/path/to/workspace"],
        "write": ["/path/to/workspace"],
        "deny": ["~/.ssh", "~/.aws", "~/.config", ".env"]
      }
    },
    {
      "id": "github",
      "transport": { "type": "streamable-http", "url": "https://api.githubcopilot.com/mcp/", "token": "ghp_..." },
      "enabled": false
    },
    {
      "id": "tradingview",
      "transport": { "type": "stdio", "command": "node", "args": ["/path/to/tradingview-mcp/src/server.js"] },
      "tools": ["quote_get", "symbol_info", "data_get_ohlcv"],
      "approvalPatterns": ["create", "delete", "set_", "draw_", "alert_"],
      "enabled": false
    }
  ]
}
